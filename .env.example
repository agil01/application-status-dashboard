# Slack Configuration
SLACK_BOT_TOKEN=xoxb-your-token-here
SLACK_PRIMARY_CHANNEL=zendesk-test
SLACK_ADDITIONAL_CHANNELS=

# Database
DATABASE_PATH=data/status.db

# Monitoring Settings
HEALTH_CHECK_INTERVAL=60
CONSECUTIVE_FAILURE_THRESHOLD=3
DAILY_HEARTBEAT_HOUR=8
DAILY_HEARTBEAT_TIMEZONE=America/New_York
SYSTEM_HEARTBEAT_INTERVAL=300
SYSTEM_HEARTBEAT_ALERT_THRESHOLD=900

# Monitor Timeouts
MONITOR_TIMEOUT=30
MONITOR_MAX_RETRIES=1

# Dashboard
DASHBOARD_POLL_INTERVAL=120
ENABLE_SSE=true

# Server
HOST=0.0.0.0
PORT=8000

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/application.log
